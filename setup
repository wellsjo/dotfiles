#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
force=false

usage() {
  cat <<'EOF'
Usage: ./setup [--force] [--help]

Options:
  --force   Replace managed files without prompting
  --help    Show this help message
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force)
      force=true
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

if [[ ! -e "${script_dir}/$(basename "$0")" ]]; then
  echo "Script directory could not be resolved. Aborting." >&2
  exit 2
fi

backup_path() {
  local target="$1"
  local timestamp
  timestamp="$(date +%Y%m%d-%H%M%S)"
  echo "${target}.backup.${timestamp}"
}

confirm_replace() {
  local target="$1"

  if [[ "$force" == true ]]; then
    return 0
  fi

  read -r -p "Replace ${target}? [y/N] " reply
  [[ "$reply" =~ ^[Yy]$ ]]
}

symlink() {
  local source="$1"
  local target="$2"
  local backup
  local current_target

  mkdir -p "$(dirname "$target")"

  if [[ -L "$target" ]]; then
    current_target="$(readlink "$target")"
    if [[ "$current_target" == "$source" ]]; then
      echo "$target already points to $source"
      return 0
    fi
  fi

  if [[ -e "$target" || -L "$target" ]]; then
    if ! confirm_replace "$target"; then
      echo "Skipping $target"
      return 0
    fi

    backup="$(backup_path "$target")"
    mv "$target" "$backup"
    echo "$target --> $backup"
  fi

  ln -s "$source" "$target"
  echo "$source --> $target"
}

install_pure_prompt() {
  if command -v npm >/dev/null 2>&1; then
    npm install --global pure-prompt
  else
    echo "Skipping pure-prompt install: npm not found"
  fi
}

setup_vim() {
  symlink "${script_dir}/vimrc" "${HOME}/.vimrc"
  symlink "${script_dir}/vim" "${HOME}/.vim"

  if command -v vim >/dev/null 2>&1; then
    echo "Vim config linked. Run 'vim +PlugInstall +qall' when you're ready to install plugins."
  else
    echo "Skipping Vim plugin guidance: vim not found"
  fi
}

setup_tmux() {
  symlink "${script_dir}/tmux/tmux.conf" "${HOME}/.tmux.conf"

  if ! command -v git >/dev/null 2>&1; then
    echo "Skipping TPM install: git not found"
    return 0
  fi

  mkdir -p "${HOME}/.tmux/plugins"
  if [[ ! -d "${HOME}/.tmux/plugins/tpm/.git" ]]; then
    git clone https://github.com/tmux-plugins/tpm "${HOME}/.tmux/plugins/tpm"
  else
    git -C "${HOME}/.tmux/plugins/tpm" pull --ff-only
  fi

  echo "TPM installed. Start tmux and press prefix + I to install tmux plugins."
}

setup_git() {
  symlink "${script_dir}/gitconfig" "${HOME}/.gitconfig"
  symlink "${script_dir}/gitignore_global" "${HOME}/.gitignore_global"
}

setup_zsh() {
  symlink "${script_dir}/zshrc" "${HOME}/.zshrc"
}

setup_vim
setup_git
setup_zsh
setup_tmux
install_pure_prompt
